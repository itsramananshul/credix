# ─── Supabase ─────────────────────────────────────────────────────────────────
# Found in: https://supabase.com/dashboard → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key   # Server-only — never expose to browser

# ─── Plaid ────────────────────────────────────────────────────────────────────
# Found in: https://dashboard.plaid.com → Team Settings → Keys
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-sandbox-secret          # Use sandbox secret for development
PLAID_ENV=sandbox                               # sandbox | development | production
PLAID_PRODUCTS=transactions,auth,identity       # Comma-separated list of products
PLAID_COUNTRY_CODES=US,CA,GB,AU                 # Add your target countries

# ─── OpenAI (optional — for AI categorization & insights) ─────────────────────
# Found in: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key

# ─── Exchange Rates (optional — for international student currency conversion) ─
# Free tier available at: https://exchangeratesapi.io or https://openexchangerates.org
EXCHANGE_RATES_API_KEY=your-exchange-rates-api-key

# ─── App Config ───────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=your-random-secret-string       # Run: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
