# ─── Supabase ─────────────────────────────────────────────────────────────────
# Found in: https://supabase.com/dashboard → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key   # Server-only — never expose to browser

# ─── Teller ───────────────────────────────────────────────────────────────────
# Sign up free (no business registration): https://teller.io/settings/application
#
# NEXT_PUBLIC_ vars are safe — they're public identifiers shown in the browser widget
NEXT_PUBLIC_TELLER_APP_ID=app_xxxxxxxxxxxx          # Settings → Application → App ID
NEXT_PUBLIC_TELLER_ENV=sandbox                      # sandbox | development | production
#
# mTLS certificate pair — SERVER-ONLY, never prefix with NEXT_PUBLIC_
# Download from: https://teller.io/settings/application → Certificates → Download
# Paste the full PEM file contents, replacing actual newlines with the two chars \n
# Example: "-----BEGIN CERTIFICATE-----\nMIIBxxx...\n-----END CERTIFICATE-----"
TELLER_CERT=-----BEGIN CERTIFICATE-----\nYOUR_CERT_CONTENT_HERE\n-----END CERTIFICATE-----
TELLER_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYOUR_KEY_CONTENT_HERE\n-----END PRIVATE KEY-----

# ─── OpenAI (optional — for AI categorization & insights) ─────────────────────
# Found in: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key

# ─── Exchange Rates (optional — for international student currency conversion) ─
# Free tier available at: https://openexchangerates.org
EXCHANGE_RATES_API_KEY=your-exchange-rates-api-key
